# ===========================================================================
# LegalMove - Contract Comparison Agent - Environment template
# Copy this file to ".env" and fill in your real credentials:
#     cp .env.example .env        (Linux/macOS)
#     copy .env.example .env      (Windows)
# The .env file is git-ignored and must NEVER be committed.
# ===========================================================================

# --- OpenAI -----------------------------------------------------------------
# Required. Used by GPT-4o (Vision) for image parsing and by both agents.
OPENAI_API_KEY=your-key-here

# Optional. Vision + reasoning model. Defaults to "gpt-4o" if unset.
OPENAI_MODEL=gpt-4o

# --- Langfuse (observability) ----------------------------------------------
# Required. Create a project at https://cloud.langfuse.com and copy the keys.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
